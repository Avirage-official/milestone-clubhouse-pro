generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── New HR / multi-tenant enums ────────────────────────────────────

enum UserRole {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  CEO
}

enum WorkPattern {
  OFFICE
  REMOTE
  HYBRID
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
}

enum TicketStage {
  NEW
  MANAGER_REVIEW
  CEO_REVIEW
  COMPLETED
  REJECTED
}

enum TicketStatus {
  OPEN
  ON_HOLD
  CLOSED
}

enum RequestType {
  ORG_CHANGE
  POLICY_CHANGE
  ACCESS_REQUEST
  OTHER
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─── Core entities ──────────────────────────────────────────────────

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  domain    String   @unique // e.g. acme.com
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams   Team[]
  users   User[]
  tickets Ticket[]
  invites Invite[]
}

model Team {
  id        Int     @id @default(autoincrement())
  name      String
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  managerId Int?
  manager   User?   @relation("ManagedTeams", fields: [managerId], references: [id])

  members UserTeam[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  fullName  String
  role      UserRole @default(EMPLOYEE)
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])

  // relationships
  profile         Profile?
  teams           UserTeam[]
  managedTeams    Team[]     @relation("ManagedTeams")
  tickets         Ticket[]   @relation("TicketSubmittedBy")
  assignedTickets Ticket[]   @relation("TicketAssignedToAdmin")
  subjectTickets  Ticket[]   @relation("TicketSubjectUser")
  notes           WorkNote[]
  invites         Invite[]

  // HR / lifecycle
  onboardingStatus OnboardingStatus? @default(PENDING)
  startDate        DateTime?
  contractType     ContractType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  preferredName String?
  roleTitle     String?
  location      String?
  timeZone      String?
  workPattern   WorkPattern?

  // Fun / product-specific fields
  petName          String?
  petType          String?
  petPersonality   String?
  workdayFocus     String?
  breakPreference  String?
  socialPreference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTeam {
  id        Int     @id @default(autoincrement())
  userId    Int
  teamId    Int
  isPrimary Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

// ─── Tickets (change requests) ──────────────────────────────────────

model Ticket {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  companyId   Int
  company     Company @relation(fields: [companyId], references: [id])

  requestType RequestType
  stage       TicketStage  @default(NEW)
  status      TicketStatus @default(OPEN)

  // who this request is about (optional)
  subjectUserId Int?
  subjectUser   User? @relation("TicketSubjectUser", fields: [subjectUserId], references: [id])

  // submitted by which employee
  submittedById Int?
  submittedBy   User? @relation("TicketSubmittedBy", fields: [submittedById], references: [id])

  // which admin on our side owns it
  assignedToAdminId Int?
  assignedToAdmin   User? @relation("TicketAssignedToAdmin", fields: [assignedToAdminId], references: [id])

  managerName String?
  ceoName     String?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── HR invites (new hire flow) ─────────────────────────────────────

model Invite {
  id            Int     @id @default(autoincrement())
  email         String
  fullName      String
  preferredName String?
  companyId     Int
  company       Company @relation(fields: [companyId], references: [id])

  roleTitle       String
  primaryTeamName String
  managerName     String
  startDate       DateTime?
  contractType    ContractType?

  location    String?
  timeZone    String?
  workPattern WorkPattern?

  showCompanyIntro   Boolean @default(true)
  showClubhouseIntro Boolean @default(true)
  requirePolicies    Boolean @default(true)

  onboardingStatus OnboardingStatus @default(PENDING)

  magicToken  String?   @unique
  invitedAt   DateTime  @default(now())
  completedAt DateTime?

  // Optional link to user once created
  userId Int?
  user   User? @relation(fields: [userId], references: [id])
}

// ─── Work notes (for Notes page) ────────────────────────────────────

model WorkNote {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  title   String
  context String // 'meeting' | 'one-to-one' | 'project' | 'idea' | ...
  body    String
  color   String // category color

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Legacy enums (still used by clubhouseData.ts mock data) ────────

enum WorkStylePreference {
  DEEP_FOCUS
  BALANCED
  SOCIAL
}

enum BreakPreference {
  LIGHT
  STANDARD
  FREQUENT
}

enum SocialPreference {
  LOW
  MEDIUM
  HIGH
}

enum PetMood {
  HAPPY
  NEUTRAL
  NEEDS_ATTENTION
}

enum ClubhouseStatus {
  IN_CLUBHOUSE // online/active
  DEEP_FOCUS
  ON_BREAK
  OUT_TODAY
}

enum Rank {
  CADET
  SERGEANT
  CAPTAIN
  GENERAL
}

enum TaskSource {
  TODAY
  FROM_YESTERDAY
  REPEAT
}

enum TaskStatus {
  OPEN
  DONE
  ARCHIVED
}

enum WorkSessionOrigin {
  HOME_HUB
  PLAYGROUND
  OTHER
}

enum BreakType {
  FOCUS
  MOVEMENT
  SOCIAL
}

enum QuestCategory {
  FOCUS
  WELLNESS
  SOCIAL
}

enum QuestSource {
  HOME_HUB
  PLAYGROUND
}

enum BadgeType {
  STAR_OF_THE_DAY
  FOCUS_HERO
  TEAM_SPARK
  WELLNESS_CHAMP
}
